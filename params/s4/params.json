      "WEAK_DOWNTREND": 45,
      "STRONG_DOWNTREND": 40,
      "VOLATILE": 60
    },
    "pf_anti_stall": {
      "min_daily_trades": 1,
      "exploration_size_mult": 0.3
    },
    "exposure": {
      "hard_block_pct": 0.30,
      "reduce_pct": 0.20,
      "min_size_mult": 0.30,
      "estimated_sl_pct": 0.02
    }
  },

  "leverage": {
    "table": {
      "STRONG_UPTREND": {"high": 15, "medium": 12, "low": 8},
      "WEAK_UPTREND": {"high": 12, "medium": 9, "low": 7},
      "SIDEWAYS": {"high": 10, "medium": 7, "low": 5},
      "WEAK_DOWNTREND": {"high": 12, "medium": 9, "low": 7},
      "STRONG_DOWNTREND": {"high": 15, "medium": 12, "low": 8},
      "VOLATILE": {"high": 8, "medium": 6, "low": 5}
    },
    "max_leverage": 15,
    "confidence_thresholds": {"high": 0.85, "medium": 0.65}
  },

  "exit": {
    "tp_levels": 3,
    "tp1_rr": [1.5, 2.5],
    "tp2_rr": [2.5, 4.0],
    "tp3_rr": [4.0, 6.0],
