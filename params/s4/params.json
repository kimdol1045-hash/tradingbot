{
  "agent_id": "s4",
  "description": "Position trader (5m+15m+1h+4h)",

  "dna": {
    "hurst_window": 100,
    "weights": {
      "hurst": 0.25,
      "entropy": 0.20,
      "liquidation": 0.15,
      "funding": 0.15,
      "oi_momentum": 0.15,
      "liq_density": 0.10
    }
  },

  "mtf_weights": {
    "5m": 0.15,
    "15m": 0.20,
    "1h": 0.35,
    "4h": 0.30
  },

  "pattern_policy": {
    "candlestick_enabled": true,
    "chart_pattern_enabled": true,
    "chart_timeframe": "4h"
  },

  "confirmation": {
    "min_closes_beyond": 2,
    "breakout_close_beyond_atr": 0.10
  },

  "gate": {
    "base_pass_scores": {
      "STRONG_UPTREND": 60,
      "WEAK_UPTREND": 65,
      "SIDEWAYS": 70,
      "WEAK_DOWNTREND": 65,
      "STRONG_DOWNTREND": 60,
      "VOLATILE": 75
    },
    "pf_anti_stall": {
      "min_daily_trades": 1,
      "exploration_size_mult": 0.3
    },
    "exposure": {
      "hard_block_pct": 0.30,
      "reduce_pct": 0.20,
      "min_size_mult": 0.30,
      "estimated_sl_pct": 0.02
    }
  },

  "leverage": {
    "table": {
      "STRONG_UPTREND": {"high": 6, "medium": 4, "low": 2},
      "WEAK_UPTREND": {"high": 4, "medium": 3, "low": 2},
      "SIDEWAYS": {"high": 2, "medium": 1, "low": 1},
      "WEAK_DOWNTREND": {"high": 4, "medium": 3, "low": 2},
      "STRONG_DOWNTREND": {"high": 6, "medium": 4, "low": 2},
      "VOLATILE": {"high": 1, "medium": 1, "low": 1}
    },
    "max_leverage": 6,
    "confidence_thresholds": {"high": 0.85, "medium": 0.65}
  },

  "exit": {
    "tp_levels": 3,
    "tp1_rr": [1.5, 2.5],
    "tp2_rr": [2.5, 4.0],
    "tp3_rr": [4.0, 6.0],
    "split_ratios": [30, 35, 35],
    "max_hold_candles": 1008,
    "max_loss_pct": 0.035,
    "risk_per_trade": 0.02
  },

  "trailing_stop": {
    "activation": "tp1_hit",
    "trailing_atr_mult": 1.5,
    "min_profit_lock": 0.8
  },

  "safety": {
    "stage_thresholds": {"STAGE_1": 160, "STAGE_2": 120, "STAGE_3": 80}
  }
}
