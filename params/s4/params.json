{
  "agent_id": "s4",
  "description": "Position trader (5m+15m+1h+4h)",

  "dna": {
    "hurst_window": 100,
    "weights": {
      "hurst": 0.25,
      "entropy": 0.20,
      "liquidation": 0.15,
      "funding": 0.15,
      "oi_momentum": 0.15,
      "liq_density": 0.10
    }
  },

  "mtf_weights": {
    "5m": 0.15,
    "15m": 0.20,
    "1h": 0.35,
    "4h": 0.30
