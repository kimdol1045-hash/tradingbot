# Hyperliquid
HYPERLIQUID_KEY=your_api_key_here
HYPERLIQUID_SECRET=your_api_secret_here
HYPERLIQUID_TESTNET=true

# Multi-wallet mode (one wallet per agent)
# When set, each agent uses its own key instead of HYPERLIQUID_KEY
# HYPERLIQUID_KEY_S1=0x...
# HYPERLIQUID_KEY_S2=0x...
# HYPERLIQUID_KEY_S3=0x...
# HYPERLIQUID_KEY_S4=0x...

# Wallet addresses for balance monitoring (read-only, no key needed)
# WALLET_ADDRESS_S1=0x...
# WALLET_ADDRESS_S2=0x...
# WALLET_ADDRESS_S3=0x...
# WALLET_ADDRESS_S4=0x...

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Telegram Topic Thread IDs (from supergroup topics, leave empty if not using topics)
TELEGRAM_TOPIC_SIGNALS=
TELEGRAM_TOPIC_FILLS=
TELEGRAM_TOPIC_EXITS=
TELEGRAM_TOPIC_SAFETY=
TELEGRAM_TOPIC_ERRORS=
TELEGRAM_TOPIC_DAILY_REPORT=
TELEGRAM_TOPIC_SYSTEM=

# LLM / Evolver — choose ONE method.
# Method 1: Direct OpenAI API key
USE_OPENCLAW=false
OPENAI_API_KEY=your_openai_api_key_here
EVOLVER_MODEL=gpt-4o

# Method 2: OpenClaw proxy
# USE_OPENCLAW=true
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=your_openclaw_gateway_token
# EVOLVER_MODEL=openclaw
EVOLVER_INTERVAL_HOURS=4

# AI Market Advisor
ADVISOR_ENABLED=true
ADVISOR_INTERVAL_HOURS=1
ADVISOR_MODEL=gpt-4o

# Coin Screener Schedule
SCREENER_INTERVAL_HOURS=72
SCREENER_START_HOUR_UTC=3
SCREENER_MIN_VOLUME_M=1

# System
ENV=local
LOG_LEVEL=INFO
DB_PATH=data/trades.db
HEALTH_PORT=8080

# Trading
TOTAL_CAPITAL=10000
DRY_RUN=true
